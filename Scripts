/**
 * reconcile-freezer-units.js
 *
 * One-time fix for products whose freezer_units/packed_units breakdown has
 * drifted out of sync with the master `units` total (caused by production
 * runs historically only updating `units`, not `freezer_units`).
 *
 * Logic: for each finished-good product,
 *   expected_freezer_units = max(0, units - packed_units * pack_size)
 * i.e. whatever isn't accounted for by packed stock is assumed to be
 * sitting unpacked in the freezer. packed_units itself is left untouched.
 *
 * Usage:
 *   node scripts/reconcile-freezer-units.js            (dry run, prints diffs only)
 *   node scripts/reconcile-freezer-units.js --apply     (writes the fixes)
 *
 * Requires the same env vars as the app (reads from .env in project root):
 *   REACT_APP_SUPABASE_URL
 *   REACT_APP_SUPABASE_ANON_KEY
 */

// Load .env manually (avoids adding a dotenv dependency just for this script)
try {
  require('dotenv').config()
} catch {
  const fs = require('fs')
  const path = require('path')
  const envPath = path.join(__dirname, '..', '.env')
  if (fs.existsSync(envPath)) {
    fs.readFileSync(envPath, 'utf8').split('\n').forEach(line => {
      const m = line.match(/^\s*([\w.-]+)\s*=\s*(.*)?\s*$/)
      if (m) process.env[m[1]] = process.env[m[1]] || (m[2] || '').replace(/^["']|["']$/g, '')
    })
  }
}
const { createClient } = require('@supabase/supabase-js')

// Mirrors PACK_SIZE from src/pages/Inventory.jsx — keep these in sync.
const PACK_SIZE = {
  VPB: 3, VPCAN: 3, PNF: 3, PVBRG: 1, PVBR: 4, PBB: 2, PCC: 2, KLR: 2, KSCD: 4,
  VPBD: 2, KHD: 2, HPC: 5, KABIS: 5, WSBIS: 5, COBIS: 5, KAB: 5, KWAL: 5,
  PVHC: 5, POS: 5, PGCo: 5, KCOC: 1, KSCO: 5, PVBB: 1, GBL: 1, KPL: 1, CCL: 1,
  BAGL: 2, Focaccia: 1, TRFCS: 1, HRCS: 1, VSCS: 1, NALCOB: 1, NBFB: 1,
  KCC: 1, KVC: 1, KLRCup: 1, KCCKE: 1, KVCKE: 1, KLRCKE: 1,
}

const SUPABASE_URL = process.env.REACT_APP_SUPABASE_URL
const SUPABASE_ANON_KEY = process.env.REACT_APP_SUPABASE_ANON_KEY

if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
  console.error('Missing REACT_APP_SUPABASE_URL / REACT_APP_SUPABASE_ANON_KEY in .env')
  process.exit(1)
}

const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY)
const APPLY = process.argv.includes('--apply')

async function main() {
  const { data: products, error } = await supabase
    .from('products')
    .select('code,name,category,units,freezer_units,packed_units,pack_size')
    .neq('category', 'WIP')

  if (error) {
    console.error('Failed to load products:', error.message)
    process.exit(1)
  }

  let mismatches = 0

  for (const p of products) {
    const ps = PACK_SIZE[p.code] || p.pack_size || 1
    const units = p.units || 0
    const packedUnits = (p.packed_units || 0) * ps
    const currentFreezer = p.freezer_units ?? units // matches UI fallback
    const expectedFreezer = Math.max(0, units - packedUnits)

    if (currentFreezer !== expectedFreezer) {
      mismatches++
      console.log(
        `${p.code} (${p.name}): units=${units}, packed=${p.packed_units || 0}×${ps}=${packedUnits}, ` +
        `freezer ${currentFreezer} → ${expectedFreezer}`
      )
      if (APPLY) {
        const { error: updErr } = await supabase
          .from('products')
          .update({ freezer_units: expectedFreezer })
          .eq('code', p.code)
        if (updErr) console.error(`  ✗ failed to update ${p.code}:`, updErr.message)
        else console.log(`  ✓ updated`)
      }
    }
  }

  console.log(`\n${mismatches} product(s) with a freezer/units mismatch found.`)
  if (!APPLY && mismatches > 0) {
    console.log('Dry run only — re-run with --apply to write these fixes.')
  }
}

main()
